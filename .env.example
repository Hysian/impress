# Docker Compose Environment Variables
# Copy this file to .env and update values as needed

# Database Configuration
POSTGRES_DB=blotting_cms
POSTGRES_USER=blotting_user
POSTGRES_PASSWORD=blotting_dev_password

# Backend API Configuration
PORT=8080
DB_DSN=host=db user=blotting_user password=blotting_dev_password dbname=blotting_cms port=5432 sslmode=disable TimeZone=Asia/Shanghai
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production
ENV=development

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8080
